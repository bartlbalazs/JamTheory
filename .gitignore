# ---------------------------------------------------------------------------
# JamTheory — root .gitignore
# ---------------------------------------------------------------------------

# IDE / editors
.idea/
.vscode/
.history/

# OS
.DS_Store
Thumbs.db

# Deployment environment variables
.env.deploy

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.*
infra/terraform.tfvars
infra/.build/

# Generated by deploy.sh --hosting (contain project-specific values, never commit)
frontend/firebase.deploy.json
frontend/.firebaserc

# NOTE: frontend/src/environments/environment.prod.ts IS committed as a
# placeholder so fresh clones build without `deploy.sh --hosting`. The
# placeholder is overwritten in-place by deploy.sh; never commit the
# overwritten version with real project values.

# Python
__pycache__/
*.py[cod]
*.pyo

# Node / Vite / frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/*.local

# Firebase emulator
firebase-export-*/
firebase-debug.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
database-debug.log
storage-debug.log
.firebase/
frontend/.firebase-emulator-data

# OpenCode / AI tooling local state
.opencode-local/
