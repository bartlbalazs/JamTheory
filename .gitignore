# ---------------------------------------------------------------------------
# JamTheory — root .gitignore
# ---------------------------------------------------------------------------

# IDE / editors
.idea/
.vscode/
.history/

# OS
.DS_Store
Thumbs.db

# Deployment environment variables
.env.deploy

# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.*
infra/terraform.tfvars
infra/.build/

# Generated by deploy.sh --hosting (contain project-specific values, never commit)
frontend/firebase.deploy.json
frontend/.firebaserc

# frontend/src/environments/environment.prod.ts is committed as a placeholder
# (so fresh clones build) but `deploy.sh --hosting` overwrites it in-place
# with real project values. Ignore those local overwrites so they don't
# accidentally get committed.
frontend/src/environments/environment.prod.ts

# Python
__pycache__/
*.py[cod]
*.pyo

# Node / Vite / frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/*.local

# Firebase emulator
firebase-export-*/
firebase-debug.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
database-debug.log
storage-debug.log
.firebase/
frontend/.firebase-emulator-data

# OpenCode / AI tooling local state
.opencode-local/
