# Local development environment variables.
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit it.

# Your GCP project ID (used by Firebase Admin and Vertex AI SDKs).
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="europe-west1"

# Firebase Emulator hosts — `firebase emulators:start` sets these automatically
# when running via ./dev.sh; hardcoded here for parity when running uvicorn alone.
FIRESTORE_EMULATOR_HOST="localhost:8081"
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"

# Firestore database name (default is '(default)').
FIRESTORE_DB="(default)"

# YouTube Data API v3 key. In production this is injected by Secret Manager.
# Locally, get a key from https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=""

# Gemini model id. Matches production (keep in sync with infra).
GEMINI_MODEL="gemini-3.1-pro-preview"

# Optional: path to a service-account JSON key for Vertex AI calls locally.
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
