{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jamtheory.app/schemas/masterclass.schema.json",
  "title": "JamTheory Masterclass",
  "description": "Single source of truth for the masterclass payload shape. Backend Pydantic models and frontend TS types must match this schema. This document corresponds to the body of backing_tracks/{videoId}/variants/{skillLevel}, minus Firestore-only metadata fields (skillLevel, createdAt, createdByUid).",
  "type": "object",
  "additionalProperties": false,
  "required": ["trackInfo", "rhythmSection", "leadSection"],
  "properties": {
    "trackInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "genre", "theorySummary"],
      "properties": {
        "key":           { "type": "string", "minLength": 1, "description": "Musical key, e.g. 'A Minor'." },
        "genre":         { "type": "string", "minLength": 1, "description": "Genre/style, e.g. 'Texas Blues'." },
        "theorySummary": { "type": "string", "minLength": 1, "description": "Plain-English harmonic context, 1-3 sentences." }
      }
    },
    "rhythmSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chords", "strummingAdvice"],
      "properties": {
        "chords": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "frets"],
            "properties": {
              "name":  { "type": "string", "minLength": 1, "description": "Chord name, e.g. 'Am7'." },
              "frets": { "type": "string", "minLength": 6, "maxLength": 6, "description": "Low-to-high fret notation over 6 strings; 'x' = muted, digits 0-24. Example 'x02210'." }
            }
          }
        },
        "strummingAdvice": { "type": "string", "minLength": 1 }
      }
    },
    "leadSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryScale", "targetNotes", "vocabularyLicks"],
      "properties": {
        "primaryScale": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "rootFret"],
          "properties": {
            "name":     { "type": "string", "minLength": 1, "description": "Scale name, e.g. 'A Minor Pentatonic'." },
            "rootFret": { "type": "integer", "minimum": 0, "maximum": 24 }
          }
        },
        "targetNotes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chord", "note", "advice"],
            "properties": {
              "chord":  { "type": "string", "minLength": 1 },
              "note":   { "type": "string", "minLength": 1 },
              "advice": { "type": "string", "minLength": 1 }
            }
          }
        },
        "vocabularyLicks": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "description": "EXACTLY 3 licks — one Easy, one Medium, one Hard, in that order.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["difficulty", "description", "alphatex"],
            "properties": {
              "difficulty":  { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
              "description": { "type": "string", "minLength": 1 },
              "alphatex":    { "type": "string", "minLength": 1, "description": "Strict AlphaTex syntax. ASCII tablature is NOT permitted anywhere in the system." }
            }
          }
        }
      }
    }
  }
}
